# Shared
NODE_ENV=development

# Web (Vite)
VITE_API_URL=http://localhost:8787

# API
API_URL=http://localhost:8787
APP_URL=http://localhost:5173
OWNER_ID=seed-user-baseer
DATABASE_URL=postgres://user:pass@localhost:5432/docket

# Reminder digests (Resend) — verify @baseer.co.uk domain in Resend first
RESEND_API_KEY=
# REMINDER_EMAIL_TO / FROM are set in apps/api/wrangler.toml for staging/production

# Push secrets to Cloudflare Workers:
#   npm run cf:secrets -- production
#   npm run cf:secrets -- production RESEND_API_KEY
# Full publish (secrets + deploy api/web + migrate/seed):
#   npm run publish:production
#
# Optional — pin which Cloudflare account wrangler uses:
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
